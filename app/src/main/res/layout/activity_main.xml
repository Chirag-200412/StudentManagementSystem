<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F7FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Student Management Dashboard"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Input Form Fields -->
    <EditText
        android:id="@+id/etId"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Enter Student ID (For Update/Delete)"
        android:inputType="number"
        android:paddingLeft="12dp"
        android:background="@android:drawable/editbox_background_normal"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Student Name"
        android:inputType="textPersonName"
        android:paddingLeft="12dp"
        android:background="@android:drawable/editbox_background_normal"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etRoll"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Roll Number (Acts as Sequence ID)"
        android:inputType="number"
        android:paddingLeft="12dp"
        android:background="@android:drawable/editbox_background_normal"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etCourse"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Course Name"
        android:inputType="text"
        android:paddingLeft="12dp"
        android:background="@android:drawable/editbox_background_normal"
        android:layout_marginBottom="16dp"/>

    <!-- CRUD Operations Grid Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="SAVE DATA"
            android:backgroundTint="#10B981"
            android:textColor="#FFFFFF"
            android:layout_marginRight="4dp"/>

        <Button
            android:id="@+id/btnView"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="VIEW RECORDS"
            android:backgroundTint="#3B82F6"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnUpdate"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="UPDATE"
            android:backgroundTint="#F59E0B"
            android:textColor="#FFFFFF"
            android:layout_marginRight="4dp"/>

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="DELETE"
            android:backgroundTint="#EF4444"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="4dp"/>
    </LinearLayout>

    <!-- Premium Logout Button Element -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="LOGOUT FROM ACCOUNT"
        android:backgroundTint="#475569"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Database Entries:"
        android:textStyle="bold"
        android:textColor="#475569"
        android:layout_marginBottom="8dp"/>

    <!-- Data List Scroller Container -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical"/>

</LinearLayout>